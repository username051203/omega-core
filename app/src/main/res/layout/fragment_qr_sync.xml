<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp"
            app:cardElevation="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:text="📲 QR SYNC BETWEEN DEVICES"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent" android:textSize="13sp"
                    android:textStyle="bold" android:fontFamily="monospace"
                    android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <TextView
                    android:text="Device A: tap Show QR. Device B: tap Scan QR and aim at Device A. Schedule transfers instantly with no internet."
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_muted" android:textSize="10sp"
                    android:layout_marginBottom="16dp" android:lineSpacingMultiplier="1.4"/>

                <TextView android:id="@+id/tvQrStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent" android:textSize="11sp"
                    android:fontFamily="monospace" android:minHeight="32dp"
                    android:gravity="center_vertical" android:layout_marginBottom="16dp"
                    android:background="@color/bg_log" android:padding="10dp"
                    android:text="Ready"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <Button android:id="@+id/btnShowQr"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="📤 Show QR"
                        android:backgroundTint="#0f2a1a" android:textColor="#4ade80"
                        android:textSize="12sp" android:layout_marginEnd="8dp"/>
                    <Button android:id="@+id/btnScanQr"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="📷 Scan QR"
                        android:backgroundTint="#0d1a3a" android:textColor="#60a5fa"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/panelQrExport"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@color/bg_log" android:padding="16dp"
                    android:visibility="gone">
                    <ImageView android:id="@+id/imgQrCode"
                        android:layout_width="260dp" android:layout_height="260dp"
                        android:scaleType="fitCenter"/>
                    <Button android:id="@+id/btnCloseQr"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" android:text="✕ Close"
                        android:backgroundTint="@color/bg_nav" android:textColor="@color/text_muted"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/panelQrScan"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@color/bg_log" android:padding="14dp"
                    android:visibility="gone">
                    <com.journeyapps.barcodescanner.DecoratedBarcodeView
                        android:id="@+id/barcodeView"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"/>
                    <Button android:id="@+id/btnStopScan"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" android:text="⏹ Stop Scanning"
                        android:backgroundTint="@color/loss_bg" android:textColor="@color/bad"
                        android:textSize="11sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
